# Server-only runtime versions for /status ($app/env/private via src/env.ts).
# Compose/Makefile export these; `make setup` writes ui/.env for local `pnpm dev`.
UI_VERSION=
API_VERSION=

# Server-side FastAPI base URL for generated remotes (backendFetch).
# Falls back to PUBLIC_API_URL when unset.
API_BASE_URL=http://localhost:8000
