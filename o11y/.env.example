# o11y stack — copy to repo root `.env` or pass inline. No real secrets.

# --- Application telemetry (set when using o11y/compose.yaml overlay) ---
OTEL_ENABLED=true

# API (gRPC → collector :4317)
# OTEL_SERVICE_NAME=api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,app.component=api,runtime.name=python
# OTEL_PYTHON_FASTAPI_EXCLUDED_URLS=/health
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# UI (HTTP → collector :4318)
# OTEL_SERVICE_NAME=ui
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,app.component=ui,runtime.name=nodejs

# --- Collector config selection (makefile sets per target) ---
# OTEL_COLLECTOR_CONFIG_FILE=collector.dev.yml
# OTEL_COLLECTOR_CONFIG_FILE=collector.grafana.yml
# OTEL_COLLECTOR_CONFIG_FILE=collector.elastic.yml

# --- Production seams (documented only — do not commit real values) ---
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1

# --- Elastic dev (security disabled locally) ---
# ELASTICSEARCH_HOST=http://elasticsearch:9200
